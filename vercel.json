    { "source": "/carrier-metrics",     "destination": "/portal/carrier-metrics",     "permanent": true },
    { "source": "/admin",               "destination": "/portal/admin",               "permanent": true },
    { "source": "/admin-tools",         "destination": "/portal/admin-tools",         "permanent": true }
