    }
  ],
  "redirects": [
    { "source": "/dashboard",           "destination": "/portal/dashboard",           "permanent": true },
    { "source": "/policies",            "destination": "/portal/policies",            "permanent": true },
    { "source": "/engagement",          "destination": "/portal/engagement",          "permanent": true },
    { "source": "/leads",               "destination": "/portal/leads",               "permanent": true },
    { "source": "/recruiting",          "destination": "/portal/recruiting",          "permanent": true },
    { "source": "/coaching",            "destination": "/portal/coaching",            "permanent": true },
    { "source": "/activity",            "destination": "/portal/activity",            "permanent": true },
    { "source": "/contracting",         "destination": "/portal/contracting",         "permanent": true },
    { "source": "/monthly-agent-totals","destination": "/portal/monthly-agent-totals","permanent": true },
    { "source": "/accountability",      "destination": "/portal/accountability",      "permanent": true },
    { "source": "/promotions",          "destination": "/portal/promotions",          "permanent": true },
    { "source": "/agents",              "destination": "/portal/agents",              "permanent": true },
